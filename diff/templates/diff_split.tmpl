{{define "diff_split"}}
<div class="diff-summary">
  <span class="summary-stats">
    <span class="add-summary">+{{.AddCount}}</span>
    <span class="del-summary">−{{.DelCount}}</span>
  </span>
</div>
<div class="diff-file-header">
  <span class="old-label">{{.OldName}}</span>
  <span class="header-sep">⇔</span>
  <span class="new-label">{{.NewName}}</span>
</div>
<div class="diff-split-wrapper">
  <div class="diff-panel left-panel">
    <table class="diff-table split">
      <colgroup>
        <col width="60">
        <col width="20">
        <col>
      </colgroup>
      {{range $i, $line := .Lines}}
        {{if eq $line.Type 2}}
        <tr class="del-code">
          <td class="lines-num lines-num-old">{{$line.LeftNum}}</td>
          <td class="lines-type-marker del-code"><span class="tw-font-mono">-</span></td>
          <td class="chroma lines-code"><code class="code-inner">{{$line.LeftLine | safeLeft}}</code></td>
        </tr>
        {{else if eq $line.Type 1}}
        <tr class="del-code">
          <td class="lines-num lines-num-old">{{$line.LeftNum}}</td>
          <td class="lines-type-marker del-code"><span class="tw-font-mono">-</span></td>
          <td class="chroma lines-code"><code class="code-inner">{{$line.LeftLine | safeLeft}}</code></td>
        </tr>
        {{else}}
        <tr class="same-code">
          <td class="lines-num lines-num-old">{{if $line.LeftNum}}{{$line.LeftNum}}{{end}}</td>
          <td class="lines-type-marker"><span class="tw-font-mono"> </span></td>
          <td class="chroma lines-code"><code class="code-inner">{{$line.LeftLine | safe}}</code></td>
        </tr>
        {{end}}
      {{end}}
    </table>
  </div>
  <div class="diff-divider"></div>
  <div class="diff-panel right-panel">
    <table class="diff-table split">
      <colgroup>
        <col width="60">
        <col width="20">
        <col>
      </colgroup>
      {{range $i, $line := .Lines}}
        {{if eq $line.Type 3}}
        <tr class="add-code">
          <td class="lines-num lines-num-new">{{$line.RightNum}}</td>
          <td class="lines-type-marker add-code"><span class="tw-font-mono">+</span></td>
          <td class="chroma lines-code"><code class="code-inner">{{$line.RightLine | safeRight}}</code></td>
        </tr>
        {{else if eq $line.Type 1}}
        <tr class="add-code">
          <td class="lines-num lines-num-new">{{$line.RightNum}}</td>
          <td class="lines-type-marker add-code"><span class="tw-font-mono">+</span></td>
          <td class="chroma lines-code"><code class="code-inner">{{$line.RightLine | safeRight}}</code></td>
        </tr>
        {{else}}
        <tr class="same-code">
          <td class="lines-num lines-num-new">{{if $line.RightNum}}{{$line.RightNum}}{{end}}</td>
          <td class="lines-type-marker"><span class="tw-font-mono"> </span></td>
          <td class="chroma lines-code"><code class="code-inner">{{$line.RightLine | safe}}</code></td>
        </tr>
        {{end}}
      {{end}}
    </table>
  </div>
</div>
{{end}}
